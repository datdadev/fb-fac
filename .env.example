# Telegram Configuration (Leave empty if not using)
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Discord Configuration (Leave empty if not using)
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Facebook Configuration (Note: Automation scripts are not provided for FB login)
FB_EMAIL=your_facebook_email_here
FB_PASSWORD=your_facebook_password_here

# Commenting Configuration
# Modes: 'interactive' (confirm each before posting) or 'auto' (automatically post)
COMMENT_MODE=interactive

# Default comment template (will be used if specific language template or AI template is not found)
DEFAULT_COMMENT="Chào bạn, bên mình chuyên nhận thiết kế và in 3D chất lượng cao tại HCM và HN. Bạn check tin nhắn chờ/inbox mình trao đổi chi tiết nhé!"

# Delay range between comments (seconds)
COMMENT_DELAY_MIN=15
COMMENT_DELAY_MAX=45
